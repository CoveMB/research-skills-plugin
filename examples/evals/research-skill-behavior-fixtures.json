{
  "schema_version": "research-skill-behavior-fixtures-v1",
  "purpose": "Reusable prompt fixtures for manual or automated checks of high-risk research skill behavior. These fixtures define expected routes, required output markers, and forbidden claims; they do not claim that a model was executed.",
  "fixtures": [
    {
      "id": "draft-with-claims-no-citations",
      "prompt": "Audit this uncited chapter excerpt for evidence problems before I add citations.",
      "expected_route": "claim-evidence-ledger",
      "risk_covered": "premature citation audit",
      "required_output_markers": [
        "claim type",
        "evidence status",
        "Do not suggest `citation-integrity-auditor` before citations, quotes, page numbers, bibliography entries, or cited claims exist."
      ],
      "forbidden_claims": [
        "citation verification passed",
        "source supports this claim"
      ]
    },
    {
      "id": "bibliography-metadata-suspect",
      "prompt": "Check this bibliography for possible fake DOIs and mismatched titles.",

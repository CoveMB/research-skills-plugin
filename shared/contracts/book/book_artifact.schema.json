  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_strings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "corpus_representativeness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "labels",
        "claim_limits",
        "counter_literature_check"
      ],
      "properties": {
        "labels": {

      }
    },
    "high_risk_claims": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "analysis_provenance": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/analysis_provenance_row"
      }
    },
    "source_priorities": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "source_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_note_row"
      }
    },
    "extraction_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/extraction_row"
      }
    },
    "bibliography_annotations": {
      "type": "array",
      "minItems": 1,

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scholarly-research-book.local/shared/contracts/book/book_artifact.schema.json",
  "title": "Research Book Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "artifact_type",
    "project_title",
    "source_basis",
    "what_i_can_verify",
    "what_remains_uncertain",
    "user_verification_needed"
  ],
  "properties": {
    "schema_version": {
      "const": "book-artifact-v1"
    },
    "artifact_type": {
      "enum": [
        "book_research_agenda",
        "source_discovery_log",
        "literature_map",
        "thesis_tree",
        "chapter_brief",
        "claim_evidence_ledger",
        "source_note",
        "extraction_table",
        "claim_traceability_graph",
        "citation_integrity_audit",
        "rights_privacy_release_audit",
        "comps_verification",
        "scholarly_integrity_audit",
        "ai_human_workflow_log",
        "figure_table_integrity_audit",
        "continuity_review",
        "book_proposal"
      ]
    },
    "project_title": {
      "$ref": "#/$defs/non_empty_string"
    },
    "created_at": {
      "$ref": "#/$defs/non_empty_string"
    },
    "source_basis": {
      "$ref": "#/$defs/non_empty_string"
    },
    "what_i_can_verify": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "what_remains_uncertain": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "user_verification_needed": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "central_research_question": {
      "$ref": "#/$defs/non_empty_string"
    },
    "subquestions": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "provisional_thesis": {
      "$ref": "#/$defs/non_empty_string"
    },
    "contribution_claim": {
      "$ref": "#/$defs/non_empty_string"
    },
    "scope_boundaries": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "in_scope",
        "out_of_scope"
      ],
      "properties": {
        "in_scope": {
          "$ref": "#/$defs/non_empty_strings"
        },
        "out_of_scope": {
          "$ref": "#/$defs/non_empty_strings"
        }
      }
    },
    "evidence_plan": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "risks_and_mitigation": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "search_families": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "query_bank": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/query_row"
      }
    },
    "priority_venues": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "inclusion_criteria": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "exclusion_criteria": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "citation_chaining_plan": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "source_targets": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "opposing_literature_targets": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "search_log": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/search_log_row"
      }
    },
    "field_overview": {
      "$ref": "#/$defs/non_empty_string"
    },
    "fields_and_subfields": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "schools_of_thought": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "major_debates": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "consensus_controversy_map": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "development_map": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "gaps_in_literature": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "thesis_implications": {
      "$ref": "#/$defs/non_empty_string"
    },
    "sources_still_needed": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "main_thesis": {
      "$ref": "#/$defs/non_empty_string"
    },
    "thesis_variants": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bold",
        "moderate",
        "conservative",
        "public_facing",
        "research"
      ],
      "properties": {
        "bold": {
          "$ref": "#/$defs/non_empty_string"
        },
        "moderate": {
          "$ref": "#/$defs/non_empty_string"
        },
        "conservative": {
          "$ref": "#/$defs/non_empty_string"
        },
        "public_facing": {
          "$ref": "#/$defs/non_empty_string"
        },
        "research": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "thesis_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/thesis_claim"
      }
    },
    "hidden_assumptions": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "chapter_argument_sequence": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "weak_links": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "chapter_title": {
      "$ref": "#/$defs/non_empty_string"
    },
    "chapter_purpose": {
      "$ref": "#/$defs/non_empty_string"
    },
    "central_question": {
      "$ref": "#/$defs/non_empty_string"
    },
    "chapter_thesis": {
      "$ref": "#/$defs/non_empty_string"
    },
    "key_concepts": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "section_outline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/chapter_section"
      }
    },
    "counterarguments_to_include": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "opening_options": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "ending_bridge": {
      "$ref": "#/$defs/non_empty_string"
    },
    "research_still_needed": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "revision_risks": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/claim_evidence_row"
      }
    },
    "high_risk_claims": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "analysis_provenance": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/analysis_provenance_row"
      }
    },
    "source_priorities": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "source_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_note_row"
      }
    },
    "extraction_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/extraction_row"
      }
    },
    "traceability_links": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/traceability_link"
      }
    },
    "citation_audit_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/citation_audit_row"
      }
    },
    "release_issues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/release_issue"
      }
    },
    "comps_verification_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/comps_verification_row"
      }
    },
    "integrity_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/integrity_check"
      }
    },
    "workflow_decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workflow_decision"
      }
    },
    "figure_table_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/figure_table_check"
      }
    },
    "global_thesis": {
      "$ref": "#/$defs/non_empty_string"
    },
    "chapter_function_map": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/chapter_function"
      }
    },
    "repetition_map": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "concept_tracking": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/concept_tracking"
      }
    },
    "contradictions_or_tensions": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "tone_and_audience_consistency": {
      "$ref": "#/$defs/non_empty_string"
    },
    "suggested_restructuring": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "priority_revision_list": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "title_options": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "premise": {
      "$ref": "#/$defs/non_empty_string"
    },
    "core_thesis": {
      "$ref": "#/$defs/non_empty_string"
    },
    "contribution_to_field": {
      "$ref": "#/$defs/non_empty_string"
    },
    "audience": {
      "$ref": "#/$defs/non_empty_string"
    },
    "source_base": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "chapter_summaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/chapter_summary"
      }
    },
    "comparable_titles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/comparable_title"
      }
    },
    "author_positioning": {
      "$ref": "#/$defs/non_empty_string"
    },
    "status_and_timeline": {
      "$ref": "#/$defs/non_empty_string"
    },
    "sample_material_plan": {
      "$ref": "#/$defs/non_empty_string"
    }
  },
  "allOf": [
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "book_research_agenda"
          }
        }
      },
      "then": {
        "required": [
          "central_research_question",
          "subquestions",
          "provisional_thesis",
          "contribution_claim",
          "scope_boundaries",
          "evidence_plan",
          "risks_and_mitigation"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "source_discovery_log"
          }
        }
      },
      "then": {
        "required": [
          "search_families",
          "query_bank",
          "priority_venues",
          "inclusion_criteria",
          "exclusion_criteria",
          "citation_chaining_plan",
          "source_targets",
          "opposing_literature_targets",
          "search_log"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "literature_map"
          }
        }
      },
      "then": {
        "required": [
          "field_overview",
          "fields_and_subfields",
          "schools_of_thought",
          "major_debates",
          "consensus_controversy_map",
          "development_map",
          "gaps_in_literature",
          "thesis_implications",
          "sources_still_needed"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "thesis_tree"
          }
        }
      },
      "then": {
        "required": [
          "main_thesis",
          "thesis_variants",
          "thesis_claims",
          "hidden_assumptions",
          "chapter_argument_sequence",
          "weak_links"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "chapter_brief"
          }
        }
      },
      "then": {
        "required": [
          "chapter_title",
          "chapter_purpose",
          "central_question",
          "chapter_thesis",
          "key_concepts",
          "section_outline",
          "counterarguments_to_include",
          "opening_options",
          "ending_bridge",
          "research_still_needed",
          "revision_risks"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "claim_evidence_ledger"
          }
        }
      },
      "then": {
        "required": [
          "claims",
          "high_risk_claims",
          "source_priorities"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "source_note"
          }
        }
      },
      "then": {
        "required": [
          "source_notes"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "extraction_table"
          }
        }
      },
      "then": {
        "required": [
          "extraction_rows"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "claim_traceability_graph"
          }
        }
      },
      "then": {
        "required": [
          "traceability_links"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "citation_integrity_audit"
          }
        }
      },
      "then": {
        "required": [
          "citation_audit_rows"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "rights_privacy_release_audit"
          }
        }
      },
      "then": {
        "required": [
          "release_issues"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "comps_verification"
          }
        }
      },
      "then": {
        "required": [
          "comps_verification_rows"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "scholarly_integrity_audit"
          }
        }
      },
      "then": {
        "required": [
          "integrity_checks"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "ai_human_workflow_log"
          }
        }
      },
      "then": {
        "required": [
          "workflow_decisions"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "figure_table_integrity_audit"
          }
        }
      },
      "then": {
        "required": [
          "figure_table_checks"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "continuity_review"
          }
        }
      },
      "then": {
        "required": [
          "global_thesis",
          "chapter_function_map",
          "repetition_map",
          "concept_tracking",
          "contradictions_or_tensions",
          "tone_and_audience_consistency",
          "suggested_restructuring",
          "priority_revision_list"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "book_proposal"
          }
        }
      },
      "then": {
        "required": [
          "title_options",
          "premise",
          "core_thesis",
          "contribution_to_field",
          "audience",
          "source_base",
          "chapter_summaries",
          "comparable_titles",
          "author_positioning",
          "status_and_timeline",
          "sample_material_plan"
        ]
      }
    }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "non_empty_strings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "claim_type": {
      "enum": [
        "empirical",
        "factual_documentary",
        "causal",
        "comparative",
        "conceptual",
        "theoretical",
        "normative",
        "field_specific",
        "predictive_speculative",
        "anecdotal_illustrative",
        "interpretive"
      ]
    },
    "evidence_status": {
      "enum": [
        "directly_supported",
        "plausibly_supported_citation_needed",
        "needs_stronger_evidence",
        "overstated_relative_to_evidence",
        "speculative_label_needed",
        "unsupported_in_provided_material",
        "contradicted_or_contested",
        "normative_needs_argument",
        "definition_needs_grounding"
      ]
    },
    "verification_status": {
      "enum": [
        "verified",
        "unverified",
        "needed",
        "verification_unavailable",
        "verification_failed",
        "verification_partial",
        "verification_passed"
      ]
    },
    "locator_status": {
      "enum": [
        "not_needed",
        "needed",
        "provided",
        "missing",
        "unverified"
      ]
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "confidence_level": {
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "integrity_verdict": {
      "enum": [
        "CLEAR",
        "SUSPECTED",
        "INSUFFICIENT EVIDENCE",
        "OVERRIDDEN"
      ]
    },
    "query_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "purpose",
        "query",
        "venue",
        "notes"
      ],
      "properties": {
        "purpose": {
          "$ref": "#/$defs/non_empty_string"
        },
        "query": {
          "$ref": "#/$defs/non_empty_string"
        },
        "venue": {
          "$ref": "#/$defs/non_empty_string"
        },
        "notes": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "search_log_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "date",
        "venue",
        "query",
        "filters",
        "useful_results",
        "notes"
      ],
      "properties": {
        "date": {
          "$ref": "#/$defs/non_empty_string"
        },
        "venue": {
          "$ref": "#/$defs/non_empty_string"
        },
        "query": {
          "$ref": "#/$defs/non_empty_string"
        },
        "filters": {
          "$ref": "#/$defs/non_empty_string"
        },
        "useful_results": {
          "type": "integer",
          "minimum": 0
        },
        "notes": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "thesis_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim",
        "warrant",
        "evidence_needed",
        "counterargument",
        "dependency",
        "chapter"
      ],
      "properties": {
        "claim": {
          "$ref": "#/$defs/non_empty_string"
        },
        "warrant": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_needed": {
          "$ref": "#/$defs/non_empty_string"
        },
        "counterargument": {
          "$ref": "#/$defs/non_empty_string"
        },
        "dependency": {
          "$ref": "#/$defs/non_empty_string"
        },
        "chapter": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "chapter_section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section",
        "function",
        "key_claim",
        "evidence_needed"
      ],
      "properties": {
        "section": {
          "$ref": "#/$defs/non_empty_string"
        },
        "function": {
          "$ref": "#/$defs/non_empty_string"
        },
        "key_claim": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_needed": {
          "$ref": "#/$defs/non_empty_strings"
        }
      }
    },
    "claim_evidence_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim",
        "claim_type",
        "evidence_status",
        "current_support",
        "evidence_needed",
        "locator_status",
        "confidence",
        "risk",
        "safer_wording"
      ],
      "properties": {
        "claim": {
          "$ref": "#/$defs/non_empty_string"
        },
        "claim_type": {
          "$ref": "#/$defs/claim_type"
        },
        "evidence_status": {
          "$ref": "#/$defs/evidence_status"
        },
        "current_support": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence_needed": {
          "$ref": "#/$defs/non_empty_string"
        },
        "locator_status": {
          "$ref": "#/$defs/locator_status"
        },
        "confidence": {
          "$ref": "#/$defs/confidence_level"
        },
        "risk": {
          "$ref": "#/$defs/risk_level"
        },
        "safer_wording": {
          "$ref": "#/$defs/non_empty_string"
        }

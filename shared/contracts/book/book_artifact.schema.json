      }
    },
    "voice_constraints": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "terms_to_preserve": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "claim_language_guidance": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "new_factual_claims_policy": {
      "$ref": "#/$defs/non_empty_string"

        "source_discovery_log",
        "literature_map",
        "thesis_tree",
        "chapter_brief",
        "claim_evidence_ledger",
        "source_note",
        "extraction_table",
        "annotated_bibliography",
        "methodology_source_audit",
        "claim_traceability_graph",
        "peer_review_report",
        "citation_integrity_audit",
        "rights_privacy_release_audit",
        "comps_verification",
        "scholarly_integrity_audit",
        "ai_human_workflow_log",
        "figure_table_integrity_audit",
        "case_study_dossier",
        "continuity_review",
        "style_sheet",
        "book_proposal"
      ]
    },
    "project_title": {
      "$ref": "#/$defs/non_empty_string"
    },
    "created_at": {
      "$ref": "#/$defs/non_empty_string"
    },
    "handoff_artifact": {
      "type": "boolean"
    },
    "source_basis": {
      "$ref": "#/$defs/non_empty_string"
    },
    "corpus_representativeness": {
      "$ref": "#/$defs/corpus_representativeness"
    },
    "what_i_can_verify": {

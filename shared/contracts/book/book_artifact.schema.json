        "$ref": "#/$defs/integrity_check"
      }
    },
    "workflow_decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workflow_decision"
      }
    },
    "figure_table_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/figure_table_check"
      }

    "fields_and_subfields": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "schools_of_thought": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "major_debates": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "consensus_controversy_map": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "development_map": {

  "allOf": [
    {
      "if": {
        "required": [
          "handoff_artifact"
        ],
        "properties": {
          "handoff_artifact": {
            "const": true
          }
        }
      },
      "then": {
        "required": [
          "process_passport"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "book_research_agenda"
          }
        }
      },
      "then": {
        "required": [
          "central_research_question",
          "subquestions",
          "provisional_thesis",
          "contribution_claim",
          "scope_boundaries",
          "evidence_plan",
          "risks_and_mitigation"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "source_discovery_log"
          }
        }
      },
      "then": {
        "properties": {
          "systematic_review": {
            "$ref": "#/$defs/systematic_review_record"
          }
        },
        "required": [
          "search_families",
          "query_bank",
          "priority_venues",
          "inclusion_criteria",
          "exclusion_criteria",
          "citation_chaining_plan",
          "source_targets",
          "opposing_literature_targets",
          "search_log"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "literature_map"
          }
        }
      },
      "then": {
        "required": [
          "field_overview",
          "fields_and_subfields",
          "schools_of_thought",
          "major_debates",
          "consensus_controversy_map",
          "development_map",
          "gaps_in_literature",
          "thesis_implications",
          "sources_still_needed"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "thesis_tree"
          }
        }
      },
      "then": {
        "required": [
          "main_thesis",
          "thesis_variants",
          "thesis_claims",
          "hidden_assumptions",
          "chapter_argument_sequence",
          "weak_links"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "chapter_brief"
          }
        }
      },
      "then": {
        "required": [
          "chapter_title",
          "chapter_purpose",
          "central_question",
          "chapter_thesis",
          "key_concepts",
          "section_outline",
          "counterarguments_to_include",
          "opening_options",
          "ending_bridge",
          "research_still_needed",
          "revision_risks"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "claim_evidence_ledger"
          }
        }
      },
      "then": {
        "properties": {
          "analysis_provenance": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/analysis_provenance_row"
            }
          }
        },
        "required": [
          "claims",
          "high_risk_claims",
          "source_priorities"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "source_note"
          }
        }
      },
      "then": {
        "required": [
          "source_notes"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "extraction_table"
          }
        }
      },
      "then": {
        "required": [
          "extraction_rows"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "annotated_bibliography"
          }
        }
      },
      "then": {
        "required": [
          "bibliography_annotations"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "methodology_source_audit"
          }
        }
      },
      "then": {
        "required": [
          "source_audit_rows"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "claim_traceability_graph"
          }
        }
      },
      "then": {
        "required": [
          "traceability_links"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "peer_review_report"
          }
        }
      },
      "then": {
        "required": [
          "charitable_restatement",
          "review_objections",
          "rival_explanations",
          "missing_literatures",
          "claims_to_narrow",
          "revision_priorities"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "citation_integrity_audit"
          }
        }
      },
      "then": {
        "required": [
          "citation_audit_rows"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "rights_privacy_release_audit"
          }
        }
      },
      "then": {
        "required": [
          "release_issues"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "comps_verification"
          }
        }
      },
      "then": {
        "required": [
          "comps_verification_rows"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "scholarly_integrity_audit"
          }
        }
      },
      "then": {
        "required": [
          "integrity_checks"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {

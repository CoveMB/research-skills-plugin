    "thesis_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/thesis_claim"
      }
    },
    "hidden_assumptions": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "chapter_argument_sequence": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "weak_links": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "chapter_title": {
      "$ref": "#/$defs/non_empty_string"
    },
    "chapter_purpose": {
      "$ref": "#/$defs/non_empty_string"
    },
    "central_question": {
      "$ref": "#/$defs/non_empty_string"
    },
    "chapter_thesis": {
      "$ref": "#/$defs/non_empty_string"
    },
    "key_concepts": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "section_outline": {
      "type": "array",
      "minItems": 1,
      "items": {

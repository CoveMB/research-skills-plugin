      "type": "object",
      "additionalProperties": false,
      "required": [
        "bold",
        "moderate",
        "conservative",
        "public_facing",
        "research"
      ],
      "properties": {
        "bold": {
          "$ref": "#/$defs/non_empty_string"
        },
        "moderate": {
          "$ref": "#/$defs/non_empty_string"
        },
        "conservative": {
          "$ref": "#/$defs/non_empty_string"
        },
        "public_facing": {
          "$ref": "#/$defs/non_empty_string"
        },
        "research": {

          "case_selection_logic",
          "case_dossiers",
          "counter_cases",
          "safer_case_claims"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {
            "const": "continuity_review"
          }
        }
      },
      "then": {
        "required": [
          "global_thesis",
          "chapter_function_map",
          "repetition_map",
          "concept_tracking",
          "contradictions_or_tensions",
          "tone_and_audience_consistency",
          "suggested_restructuring",
          "priority_revision_list"
        ]
      }
    },
    {
      "if": {
        "required": [
          "artifact_type"
        ],
        "properties": {
          "artifact_type": {

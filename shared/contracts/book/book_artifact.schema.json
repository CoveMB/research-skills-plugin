    "claim_needing_case": {
      "$ref": "#/$defs/non_empty_string"
    },
    "case_selection_logic": {
      "$ref": "#/$defs/non_empty_string"
    },
    "case_dossiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/case_dossier"
      }
    },
    "counter_cases": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "safer_case_claims": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "global_thesis": {
      "$ref": "#/$defs/non_empty_string"
    },
    "chapter_function_map": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/chapter_function"
      }
    },
    "repetition_map": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "concept_tracking": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/concept_tracking"
      }
    },
    "contradictions_or_tensions": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "tone_and_audience_consistency": {
      "$ref": "#/$defs/non_empty_string"
    },
    "suggested_restructuring": {
      "$ref": "#/$defs/non_empty_strings"
    },
    "priority_revision_list": {
